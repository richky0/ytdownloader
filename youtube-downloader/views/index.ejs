<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <meta name="description" content="Download YouTube videos in HD, 4K, MP3 with our fast, free service. No registration required - save videos directly to your device.">
    <title>Fast YouTube Video Downloader | HD & 4K Quality</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --dark: #1e293b;
            --darker: #0f172a;
            --safe-area-inset-top: env(safe-area-inset-top);
            --safe-area-inset-bottom: env(safe-area-inset-bottom);
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--darker);
            color: #f8fafc;
            padding-top: var(--safe-area-inset-top);
            padding-bottom: var(--safe-area-inset-bottom);
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body.light-mode {
            background-color: #f1f5f9;
            color: #1e293b;
            --dark: #e2e8f0;
            --darker: #cbd5e1;
        }

        .light-mode .gradient-bg {
            background: linear-gradient(135deg, #e2e8f0 0%, #f1f5f9 100%);
        }

        .light-mode .card {
            background: rgba(226, 232, 240, 0.7);
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        .light-mode .download-option {
            background: rgba(226, 232, 240, 0.7);
            color: #1e293b;
        }

        .light-mode .download-option:hover {
            background: rgba(99, 102, 241, 0.1);
        }

        .light-mode .text-slate-400 {
            color: #64748b;
        }

        .light-mode .bg-slate-800\/30 {
            background-color: rgba(226, 232, 240, 0.7);
        }

        .light-mode .border-slate-700 {
            border-color: #cbd5e1;
        }

        .light-mode .text-white {
            color: #1e293b;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, var(--darker) 0%, var(--dark) 100%);
            min-height: calc(100vh - var(--safe-area-inset-top) - var(--safe-area-inset-bottom));
            transition: background 0.3s ease;
        }
        
        .card {
            backdrop-filter: blur(10px);
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: background 0.3s ease, border-color 0.3s ease;
        }
        
        .download-option {
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
        }
        
        .download-option:hover {
            transform: translateY(-2px);
            border-left-color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
        }
        
        .tab-button {
            transition: all 0.2s ease;
            border-bottom: 3px solid transparent;
            white-space: nowrap;
        }
        
        .tab-button.active {
            border-bottom-color: var(--primary);
            color: var(--primary);
        }
        
        .spinner {
            width: 24px;
            height: 24px;
            border: 3px solid rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            border-top-color: var(--primary);
            animation: spin 1s ease-in-out infinite;
        }

        .light-mode .spinner {
            border: 3px solid rgba(0, 0, 0, 0.1);
            border-top-color: var(--primary);
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Modern entrance animations */
        @keyframes floatIn {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes fadeScaleIn {
            0% { opacity: 0; transform: scale(0.95); }
            100% { opacity: 1; transform: scale(1); }
        }
        
        .animate-float {
            animation: floatIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }
        
        .animate-fade-scale {
            animation: fadeScaleIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }
        
        .delay-100 {
            animation-delay: 100ms;
        }
        
        .delay-200 {
            animation-delay: 200ms;
        }
        
        .delay-300 {
            animation-delay: 300ms;
        }

        /* Feature highlight animation */
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(99, 102, 241, 0); }
            100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
        }
        
        .feature-highlight {
            animation: pulse 2s infinite;
        }
        
        /* Smooth gradient transition */
        .gradient-transition {
            background-size: 200% 200%;
            animation: gradientBG 15s ease infinite;
        }
        
        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Modal styles */
        .modal {
            position: fixed;
            inset: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
            background-color: rgba(0, 0, 0, 0.8);
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .light-mode .modal {
            background-color: rgba(0, 0, 0, 0.5);
        }
        
        .modal.active {
            opacity: 1;
            visibility: visible;
        }
        
        .modal-content {
            width: 100%;
            max-width: 56rem;
            max-height: 90vh;
            overflow-y: auto;
            background-color: #1e293b;
            border-radius: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            transform: scale(0.95);
            transition: all 0.3s ease;
        }

        .light-mode .modal-content {
            background-color: #f8fafc;
            border: 1px solid rgba(0, 0, 0, 0.1);
        }
        
        .modal.active .modal-content {
            transform: scale(1);
        }

        /* Language dropdown styles */
        .language-dropdown {
            position: relative;
            display: inline-block;
        }

        .language-dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            background-color: #1e293b;
            min-width: 160px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
            z-index: 1;
            border-radius: 0.5rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .light-mode .language-dropdown-content {
            background-color: #f8fafc;
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        .language-dropdown-content a {
            color: #f8fafc;
            padding: 0.75rem 1rem;
            text-decoration: none;
            display: block;
            transition: background-color 0.3s ease;
        }

        .light-mode .language-dropdown-content a {
            color: #1e293b;
        }

        .language-dropdown-content a:hover {
            background-color: rgba(99, 102, 241, 0.2);
        }

        .language-dropdown-content.show {
            display: block;
        }

        .language-dropdown-close {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            background: none;
            border: none;
            color: #f8fafc;
            cursor: pointer;
            font-size: 1rem;
        }

        .light-mode .language-dropdown-close {
            color: #1e293b;
        }

        /* Theme toggle button */
        .theme-toggle {
            background: none;
            border: none;
            color: #f8fafc;
            cursor: pointer;
            font-size: 1.25rem;
            transition: transform 0.3s ease;
        }

        .light-mode .theme-toggle {
            color: #1e293b;
        }

        .theme-toggle:hover {
            transform: scale(1.1);
        }

        /* Settings button */
        .settings-btn {
            background: none;
            border: none;
            color: #f8fafc;
            cursor: pointer;
            font-size: 1.25rem;
            transition: transform 0.3s ease;
        }

        .light-mode .settings-btn {
            color: #1e293b;
        }

        .settings-btn:hover {
            transform: scale(1.1);
        }

        /* Better mobile view for video info */
        @media (max-width: 640px) {
            .video-info-container {
                flex-direction: column;
            }
            .video-thumbnail {
                width: 100% !important;
                margin-bottom: 1rem;
            }
        }
    </style>
</head>
<body class="min-h-screen">
    <div class="gradient-bg gradient-transition min-h-screen flex flex-col items-center py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
        <!-- Header with settings and theme toggle -->
        <div class="w-full max-w-4xl flex justify-between items-center mb-4">
            <div></div> <!-- Empty div for spacing -->
            <div class="flex items-center gap-4">
                <button class="theme-toggle" id="theme-toggle">
                    <i class="fas fa-moon" id="theme-icon"></i>
                </button>
                <div class="language-dropdown">
                    <button class="settings-btn" id="language-toggle">
                        <i class="fas fa-language"></i>
                    </button>
                    <div class="language-dropdown-content" id="language-dropdown">
                        <button class="language-dropdown-close">
                            <i class="fas fa-times"></i>
                        </button>
                        <a href="#" data-lang="en" class="flex items-center">
                            <span class="flag-icon flag-icon-us mr-2"></span> English
                        </a>
                        <a href="#" data-lang="id" class="flex items-center">
                            <span class="flag-icon flag-icon-id mr-2"></span> Indonesia
                        </a>
                        <a href="#" data-lang="zh" class="flex items-center">
                            <span class="flag-icon flag-icon-cn mr-2"></span> 中文 (Chinese)
                        </a>
                        <a href="#" data-lang="ar" class="flex items-center">
                            <span class="flag-icon flag-icon-sa mr-2"></span> العربية (Arabic)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="w-full max-w-4xl mx-auto">
            <!-- Header with animated entrance -->
            <div class="text-center mb-8 sm:mb-10 animate-float">
                <div class="flex justify-center mb-3 sm:mb-4">
                    <div class="w-14 sm:w-16 h-14 sm:h-16 rounded-full bg-indigo-600 flex items-center justify-center shadow-lg feature-highlight">
                        <i class="fas fa-download text-white text-xl sm:text-2xl"></i>
                    </div>
                </div>
                <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-1 sm:mb-2" data-i18n="title">YouTube Downloader</h1>
                <p class="text-slate-400 text-sm sm:text-base max-w-md mx-auto" data-i18n="subtitle">Download videos in 4K, 1080p, 720p or extract MP3 audio - Fast, free and unlimited</p>
            </div>

            <!-- Features Section -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 sm:mb-8">
                <div class="bg-slate-800/30 rounded-lg p-3 text-center animate-float delay-100">
                    <i class="fas fa-bolt text-indigo-400 text-lg mb-1"></i>
                    <p class="text-xs sm:text-sm font-medium text-white" data-i18n="feature1">Instant Download</p>
                </div>
                <div class="bg-slate-800/30 rounded-lg p-3 text-center animate-float delay-200">
                    <i class="fas fa-lock-open text-green-400 text-lg mb-1"></i>
                    <p class="text-xs sm:text-sm font-medium text-white" data-i18n="feature2">No Registration</p>
                </div>
                <div class="bg-slate-800/30 rounded-lg p-3 text-center animate-float delay-300">
                    <i class="fas fa-infinity text-purple-400 text-lg mb-1"></i>
                    <p class="text-xs sm:text-sm font-medium text-white" data-i18n="feature3">Unlimited Downloads</p>
                </div>
                <div class="bg-slate-800/30 rounded-lg p-3 text-center animate-float delay-100">
                    <i class="fas fa-shield-alt text-blue-400 text-lg mb-1"></i>
                    <p class="text-xs sm:text-sm font-medium text-white" data-i18n="feature4">Safe & Secure</p>
                </div>
            </div>

            <!-- Error Message -->
            <% if (error) { %>
                <div class="bg-rose-900/50 border border-rose-700 rounded-xl p-3 sm:p-4 mb-4 sm:mb-6 text-rose-100 animate-fade-scale">
                    <div class="flex items-center">
                        <i class="fas fa-exclamation-circle mr-2"></i>
                        <span class="font-medium"><%= error %></span>
                    </div>
                </div>
            <% } %>

            <!-- Main Card with animated entrance -->
            <div class="card rounded-xl sm:rounded-2xl p-4 sm:p-6 md:p-8 shadow-2xl animate-fade-scale delay-200">
                <!-- How it works section -->
                <div class="mb-6 text-center">
                    <h2 class="text-lg sm:text-xl font-bold text-white mb-3" data-i18n="howItWorks">How to Download YouTube Videos</h2>
                    <div class="flex flex-col sm:flex-row justify-center items-center gap-2 sm:gap-4 text-xs sm:text-sm text-slate-400 mb-4">
                        <div class="flex items-center">
                            <span class="bg-indigo-600 text-white rounded-full w-5 h-5 flex items-center justify-center mr-2">1</span>
                            <span data-i18n="step1">Paste URL</span>
                        </div>
                        <i class="fas fa-arrow-right text-slate-500 hidden sm:block"></i>
                        <div class="flex items-center">
                            <span class="bg-indigo-600 text-white rounded-full w-5 h-5 flex items-center justify-center mr-2">2</span>
                            <span data-i18n="step2">Choose Format</span>
                        </div>
                        <i class="fas fa-arrow-right text-slate-500 hidden sm:block"></i>
                        <div class="flex items-center">
                            <span class="bg-indigo-600 text-white rounded-full w-5 h-5 flex items-center justify-center mr-2">3</span>
                            <span data-i18n="step3">Download</span>
                        </div>
                    </div>
                </div>

                <!-- URL Input Form -->
                <form id="download-form" action="/download" method="POST" class="mb-0">
                    <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
                        <div class="flex-grow">
                            <div class="relative">
                                <input type="text" name="url" id="url-input" 
                                       placeholder="Paste YouTube URL here (e.g. https://youtube.com/watch?v=...)" 
                                       class="w-full px-4 sm:px-5 py-2 sm:py-3 text-sm sm:text-base bg-slate-800/70 border border-slate-700 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-white placeholder-slate-500 transition-all duration-200 touch-target">
                                <div class="absolute right-3 top-1/2 transform -translate-y-1/2">
                                    <i class="fab fa-youtube text-red-500 text-lg sm:text-xl"></i>
                                </div>
                            </div>
                        </div>
                        <button type="submit" id="submit-btn" class="px-4 sm:px-6 py-2 sm:py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg sm:rounded-xl transition-all duration-200 flex items-center justify-center min-w-[120px] sm:min-w-[150px] touch-target">
                            <span id="btn-text" class="text-sm sm:text-base" data-i18n="getVideo">Get Video</span>
                            <span id="btn-spinner" class="hidden ml-2">
                                <div class="spinner"></div>
                            </span>
                        </button>
                    </div>
                </form>

                <!-- Loading Indicator -->
                <div id="loading-spinner" class="hidden mt-4 sm:mt-6 text-center">
                    <div class="inline-flex items-center px-3 sm:px-4 py-1 sm:py-2 bg-slate-800/50 rounded-full text-sm sm:text-base">
                        <div class="spinner mr-2"></div>
                        <span class="text-slate-400" data-i18n="processing">Processing video information...</span>
                    </div>
                </div>

                <!-- Video Info Display -->
                <% if (videoInfo) { %>
                    <div class="mt-6 sm:mt-8 animate-fade-scale">
                        <div class="flex flex-col md:flex-row gap-4 sm:gap-6 items-start bg-slate-800/30 rounded-lg sm:rounded-xl p-3 sm:p-5 border border-slate-700/50 video-info-container">
                            <img src="<%= videoInfo.videoDetails.thumbnailUrl || (videoInfo.videoDetails.thumbnails && videoInfo.videoDetails.thumbnails.length ? videoInfo.videoDetails.thumbnails[videoInfo.videoDetails.thumbnails.length-1].url : '') %>" 
                                 alt="Video thumbnail" 
                                 class="w-full md:w-48 rounded-lg sm:rounded-xl shadow-md aspect-video object-cover video-thumbnail">
                            <div class="flex-1 w-full">
                                <h2 class="text-lg sm:text-xl font-bold text-white mb-1 sm:mb-2 leading-tight"><%= videoInfo.videoDetails.title %></h2>
                                <p class="text-slate-400 text-sm sm:text-base mb-2 sm:mb-3" data-i18n="by">By <span class="text-slate-300"><%= videoInfo.videoDetails.author.name %></span></p>
                                
                                <div class="flex flex-wrap gap-1 sm:gap-2 mt-2 sm:mt-4">
                                    <span class="text-xs px-2 sm:px-3 py-1 bg-slate-700/50 rounded-full text-slate-300">
                                        <i class="far fa-clock mr-1"></i> <%= Math.floor(videoInfo.videoDetails.lengthSeconds / 60) %>:<%= (videoInfo.videoDetails.lengthSeconds % 60).toString().padStart(2, '0') %>
                                    </span>
                                    <span class="text-xs px-2 sm:px-3 py-1 bg-slate-700/50 rounded-full text-slate-300">
                                        <i class="far fa-eye mr-1"></i> <%= Number(videoInfo.videoDetails.viewCount).toLocaleString() %> <span data-i18n="views">views</span>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 sm:mt-6">
                            <!-- ================= PERBAIKAN DI SINI =================
                                 Sebelumnya loop menggunakan formats.combined, yang hanya
                                 berisi format progresif mp4 (video+audio jadi satu file).
                                 YouTube hanya menyediakan format progresif hingga 360p,
                                 sehingga resolusi 720p/1080p/1440p tidak pernah muncul.

                                 Sekarang loop menggunakan formats.resolutions, yang berisi
                                 gabungan format combined + video-only (hingga resolusi
                                 tertinggi yang tersedia). Setiap link tetap mengirim
                                 mode=merged agar backend selalu menggabungkan video +
                                 audio lewat ffmpeg saat resolusi di atas 360p dipilih.
                            ================================================================ -->
                            <div class="mb-4">
                                <div class="flex items-center justify-between mb-2">
                                    <h4 class="text-sm font-semibold text-white">📹 Pilihan Resolusi Video</h4>
                                    <span class="text-xs text-slate-400">Dengan suara • via FFmpeg</span>
                                </div>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                    <% if (formats && formats.resolutions && formats.resolutions.length > 0) { %>
                                        <% formats.resolutions.slice(0, 9).forEach(format => { %>
                                            <a href="/download?url=<%= encodeURIComponent(videoInfo.videoDetails.video_url) %>&itag=<%= format.itag %>&res=<%= format.height || '' %>&mode=merged"
                                               class="group rounded-xl border border-emerald-500/20 bg-emerald-600/10 hover:bg-emerald-600/20 p-3 text-left transition-all duration-200">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <div class="font-semibold text-white"><%= format.qualityLabel.replace(' (Video Only)', '') %></div>
                                                        <div class="text-xs text-slate-400 mt-1"><%= format.size %></div>
                                                    </div>
                                                    <div class="text-emerald-400 group-hover:translate-x-1 transition-transform">
                                                        <i class="fas fa-download"></i>
                                                    </div>
                                                </div>
                                                <div class="text-[11px] text-slate-400 mt-2">Video + suara otomatis saat diunduh</div>
                                            </a>
                                        <% }); %>
                                    <% } else if (formats && formats.combined && formats.combined.length > 0) { %>
                                        <% formats.combined.slice(0, 9).forEach(format => { %>
                                            <a href="/download?url=<%= encodeURIComponent(videoInfo.videoDetails.video_url) %>&itag=<%= format.itag %>&res=<%= format.height || '' %>&mode=merged"
                                               class="group rounded-xl border border-emerald-500/20 bg-emerald-600/10 hover:bg-emerald-600/20 p-3 text-left transition-all duration-200">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <div class="font-semibold text-white"><%= format.qualityLabel %></div>
                                                        <div class="text-xs text-slate-400 mt-1"><%= format.size %></div>
                                                    </div>
                                                    <div class="text-emerald-400 group-hover:translate-x-1 transition-transform">
                                                        <i class="fas fa-download"></i>
                                                    </div>
                                                </div>
                                                <div class="text-[11px] text-slate-400 mt-2">Video + suara otomatis saat diunduh</div>
                                            </a>
                                        <% }); %>
                                    <% } else { %>
                                        <a href="/download?url=<%= encodeURIComponent(videoInfo.videoDetails.video_url) %>&mode=merged"
                                           class="group rounded-xl border border-emerald-500/20 bg-emerald-600/10 hover:bg-emerald-600/20 p-3 text-left transition-all duration-200">
                                            <div class="font-semibold text-white">Best Video</div>
                                            <div class="text-[11px] text-slate-400 mt-2">Video + suara otomatis saat diunduh</div>
                                        </a>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Opsi audio saja (MP3/M4A) -->
                            <% if (formats && formats.audio && formats.audio.length > 0) { %>
                                <div class="mb-4">
                                    <div class="flex items-center justify-between mb-2">
                                        <h4 class="text-sm font-semibold text-white">🎵 Pilihan Audio Saja</h4>
                                    </div>
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                        <% formats.audio.slice(0, 6).forEach(format => { %>
                                            <a href="/download?url=<%= encodeURIComponent(videoInfo.videoDetails.video_url) %>&itag=<%= format.itag %>&mode=direct"
                                               class="group rounded-xl border border-indigo-500/20 bg-indigo-600/10 hover:bg-indigo-600/20 p-3 text-left transition-all duration-200">
                                                <div class="flex items-center justify-between">
                                                    <div>
                                                        <div class="font-semibold text-white"><%= format.qualityLabel %></div>
                                                        <div class="text-xs text-slate-400 mt-1"><%= format.size %></div>
                                                    </div>
                                                    <div class="text-indigo-400 group-hover:translate-x-1 transition-transform">
                                                        <i class="fas fa-download"></i>
                                                    </div>
                                                </div>
                                            </a>
                                        <% }); %>
                                    </div>
                                </div>
                            <% } %>

                            <div class="rounded-xl border border-slate-700/60 bg-slate-800/30 p-3 text-sm text-slate-400">
                                <i class="fas fa-info-circle mr-2 text-indigo-400"></i>
                                Saat Anda klik resolusi tertentu, sistem akan menggabungkan video dan audio secara otomatis agar hasil unduhan tetap memiliki suara.
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Features Details Section -->
            <div class="mt-8 sm:mt-12 animate-float delay-300">
                <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-6" data-i18n="whyChoose">Why Choose Our YouTube Downloader?</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
